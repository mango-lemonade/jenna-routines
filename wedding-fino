<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="color-scheme" content="light only">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Spencer & Jenna — Big Sur, May 2027</title>
<style id="isabellafont">
@font-face {
  font-family: 'Isabella Sans';
  src: url('data:font/woff2;base64,') format('woff2');
  font-weight: 300;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Isabella Sans';
  src: url('data:font/woff2;base64,') format('woff2');
  font-weight: 400 500;
  font-style: normal;
  font-display: swap;
}
</style>
<style>
  :root {
    --green-dark: #0C260F;
    --green-mid: #485B4A;
    --cream: #FBFBFB;
    --teal: #8DB32A;
    --teal-light: #A8CC3A;
    --teal-pale: rgba(141,179,42,0.1);
    --text: #1A1A1A;
    --text-muted: #5A6B5B;
    --rule: #D6DDD6;
    --sand: #F2F4F0;
  }

- { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; color-scheme: light only; }
  @media (prefers-color-scheme: dark) { html, body { background: #FBFBFB !important; color: #1A1A1A !important; } }

body {
background: #FBFBFB;
color: #1A1A1A;
font-family: ‘Isabella Sans’, sans-serif;
font-weight: 300;
font-size: 16px;
line-height: 1.75;
-webkit-font-smoothing: antialiased;
}

/* ── TYPOGRAPHY SYSTEM ── */

/* Eyebrow: ALL CAPS, wide tracking, small, teal */
.eyebrow {
font-family: ‘Isabella Sans’, sans-serif;
font-weight: 500;
font-size: 10px;
letter-spacing: 0.28em;
text-transform: uppercase;
color: var(–teal);
}

/* Display: Italiana, large, light */
.display {
font-family: ‘Isabella Sans’, serif;
font-weight: 400;
line-height: 1.05;
letter-spacing: 0.01em;
}

/* Section title */
.section-title {
font-family: ‘Isabella Sans’, serif;
font-weight: 400;
font-size: clamp(24px, 4vw, 40px);
line-height: 1.1;
color: var(–text);
margin-bottom: 22px;
letter-spacing: 0.01em;
}

/* Section intro */
.section-intro {
font-size: clamp(14px, 2vw, 16px);
color: var(–text-muted);
line-height: 1.85;
max-width: 620px;
font-weight: 300;
}

/* ── LAYOUT ── */
.page-wrap { max-width: 720px; margin: 0 auto; padding: 0 28px; }
.section { padding: 68px 0 56px; border-bottom: 1px solid var(–rule); background: #FBFBFB; }
.section:last-of-type { border-bottom: none; }

/* ── HERO ── */
.hero {
background: var(–green-dark);
color: var(–cream);
text-align: center;
padding: 88px 28px 76px;
position: relative;
overflow: hidden;
}
.hero::before {
content: ‘’;
position: absolute;
inset: 0;
background:
radial-gradient(ellipse at 70% 30%, rgba(42,125,111,0.22) 0%, transparent 55%),
radial-gradient(ellipse at 15% 85%, rgba(72,91,74,0.35) 0%, transparent 50%);
pointer-events: none;
}
.hero > * { position: relative; }

.hero .eyebrow {
color: var(–teal-light);
margin-bottom: 22px;
display: block;
}

.hero-name {
font-family: ‘Isabella Sans’, serif;
font-size: clamp(42px, 9vw, 96px);
font-weight: 400;
line-height: 1.0;
color: var(–cream);
letter-spacing: 0.02em;
margin-bottom: 14px;
}

.hero-name em {
font-style: italic;
color: var(–teal-light);
}

.hero-location {
font-family: ‘Isabella Sans’, sans-serif;
font-style: italic;
font-size: clamp(13px, 2vw, 18px);
color: rgba(251,251,251,0.5);
margin-bottom: 44px;
font-weight: 300;
letter-spacing: 0.06em;
}

.hero-meta {
display: flex;
justify-content: center;
gap: 52px;
flex-wrap: wrap;
}
.hero-meta-item .label {
display: block;
font-size: 9px;
letter-spacing: 0.24em;
text-transform: uppercase;
color: rgba(251,251,251,0.38);
font-weight: 500;
margin-bottom: 6px;
}
.hero-meta-item .value {
font-family: ‘Isabella Sans’, serif;
font-size: 20px;
color: var(–cream);
letter-spacing: 0.03em;
}

/* ── NAV ── */
.page-nav {
background: var(–cream);
border-bottom: 1px solid var(–rule);
position: sticky;
top: 0;
z-index: 100;
padding: 0 28px;
}
.page-nav ul {
list-style: none;
display: flex;
justify-content: center;
max-width: 800px;
margin: 0 auto;
overflow-x: auto;
scrollbar-width: none;
}
.page-nav ul::-webkit-scrollbar { display: none; }
.page-nav a {
display: block;
padding: 12px 10px;
font-size: 9px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–text-muted);
text-decoration: none;
white-space: nowrap;
transition: color 0.2s;
font-weight: 500;
}
.page-nav a:hover { color: var(–teal); }

/* ── TLDR CARD ── */
/* Dark bg but with high-contrast text for mobile readability */
.tldr-card {
background: var(–green-dark);
border-radius: 3px;
padding: clamp(28px, 5vw, 48px) clamp(22px, 6vw, 52px);
margin: 52px 0;
}
.tldr-card .eyebrow { color: var(–teal-light); margin-bottom: 12px; display: block; }
.tldr-card .section-title { color: var(–cream); margin-bottom: 32px; }

.tldr-list { list-style: none; display: grid; gap: 18px; }
.tldr-list li {
display: grid;
grid-template-columns: 14px 1fr;
gap: 14px;
font-size: clamp(13px, 2vw, 15px);
line-height: 1.65;
/* Full white for readability on dark bg */
color: rgba(251,251,251,0.88);
font-weight: 300;
}
.tldr-list li::before {
content: ‘→’;
color: var(–teal-light);
font-size: 12px;
margin-top: 3px;
}
.tldr-list strong {
color: #ffffff;
font-weight: 500;
}

/* ── WEEKEND SCHEDULE ── */
.day-block { margin-bottom: 52px; }
.day-block:last-child { margin-bottom: 0; }

.day-header {
display: flex;
align-items: baseline;
gap: 14px;
margin-bottom: 24px;
padding-bottom: 14px;
border-bottom: 1px solid var(–rule);
flex-wrap: wrap;
}
.day-name {
font-family: ‘Isabella Sans’, serif;
font-size: clamp(20px, 4vw, 27px);
font-weight: 400;
color: var(–text);
letter-spacing: 0.02em;
}
.day-tag {
font-size: 9px;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–teal);
font-weight: 500;
background: var(–teal-pale);
padding: 3px 10px;
border-radius: 20px;
}

.event-list { list-style: none; display: grid; gap: 20px; }
.event-item {
display: grid;
grid-template-columns: 90px 1fr;
gap: 16px;
font-size: clamp(13px, 2vw, 15px);
line-height: 1.65;
}
.event-time {
font-size: 10px;
letter-spacing: 0.14em;
color: var(–text-muted);
text-transform: uppercase;
padding-top: 3px;
font-weight: 500;
}
.event-desc strong {
font-weight: 500;
display: block;
margin-bottom: 3px;
color: var(–text);
font-size: 15px;
}
.event-desc p { color: var(–text); font-weight: 300; }
.event-note {
font-size: 13px;
color: var(–text-muted);
font-style: italic;
margin-top: 5px;
display: block;
font-weight: 300;
}

/* ── CALLOUTS ── */
.callout {
border-radius: 3px;
padding: 18px 22px;
margin: 24px 0;
font-size: 14.5px;
line-height: 1.72;
font-weight: 300;
}
.callout strong { font-weight: 500; }

/* Teal-bordered warm callout — light bg, readable on mobile */
.callout-warm {
background: var(–teal-pale);
border-left: 3px solid var(–teal);
color: var(–text);
}
.callout-warm strong { color: var(–green-dark); }

/* Dark callout — high contrast text */
.callout-dark {
background: var(–green-mid);
color: #ffffff;
padding: 16px 22px;
}
.callout-dark strong {
color: var(–teal-light);
font-weight: 500;
}

/* ── LODGING ── */
.subsection-title {
font-family: ‘Isabella Sans’, serif;
font-size: clamp(18px, 3vw, 23px);
font-weight: 400;
margin: 44px 0 14px;
color: var(–text);
letter-spacing: 0.02em;
}

.lodging-grid { display: grid; gap: 10px; margin: 14px 0; }

.lodging-card {
background: var(–sand);
border-radius: 3px;
padding: 20px 24px;
}
.lodging-card.featured {
background: white;
border: 1.5px solid var(–teal);
padding: 28px 30px;
}
.lodging-card-header {
display: flex;
justify-content: space-between;
align-items: flex-start;
gap: 12px;
margin-bottom: 5px;
flex-wrap: wrap;
}
.lodging-name {
font-family: ‘Isabella Sans’, serif;
font-size: clamp(17px, 3vw, 21px);
font-weight: 400;
color: var(–text);
letter-spacing: 0.02em;
}
.lodging-card.featured .lodging-name { font-size: clamp(20px, 4vw, 26px); }

.lodging-badge {
font-size: 9px;
letter-spacing: 0.18em;
text-transform: uppercase;
background: var(–teal);
color: #0C260F;
padding: 3px 11px;
border-radius: 20px;
font-weight: 500;
white-space: nowrap;
margin-top: 4px;
}
.lodging-price {
font-size: 12.5px;
color: var(–teal);
font-weight: 500;
margin-bottom: 7px;
display: block;
letter-spacing: 0.03em;
}
.lodging-desc {
font-size: clamp(12px, 1.8vw, 13.5px);
color: var(–text-muted);
line-height: 1.7;
font-weight: 300;
}

.room-types { margin-top: 20px; border-top: 1px solid var(–rule); }
.room-type {
display: flex;
justify-content: space-between;
align-items: baseline;
padding: 10px 0;
border-bottom: 1px solid var(–rule);
gap: 16px;
font-size: 13.5px;
}
.room-type:last-child { border-bottom: none; }
.room-type-name { color: var(–text); font-weight: 400; }
.room-type-desc { color: var(–text-muted); font-size: 12.5px; text-align: right; font-weight: 300; }

.book-btn-wrap { margin-top: 24px; }

/* ── BUTTONS ── */
.btn {
display: inline-block;
padding: 13px 28px;
font-family: ‘Isabella Sans’, sans-serif;
font-size: 10px;
letter-spacing: 0.22em;
text-transform: uppercase;
font-weight: 500;
border-radius: 2px;
text-decoration: none;
cursor: pointer;
border: none;
transition: all 0.2s;
}
.btn-primary { background: var(–teal); color: #0C260F; }
.btn-primary:hover { background: var(–teal-light); }
.btn-secondary {
background: transparent;
color: var(–text);
border: 1px solid var(–rule);
margin-left: 12px;
}
.btn-secondary:hover { border-color: var(–text-muted); }

/* ── CTA SECTION ── */
.cta-section {
background: var(–green-dark);
padding: 84px 28px;
text-align: center;
}
.cta-section h2 {
font-family: ‘Isabella Sans’, serif;
font-size: clamp(22px, 4vw, 38px);
font-weight: 400;
line-height: 1.15;
/* White on dark — explicit, not variable, for mobile safety */
color: #FBFBFB;
margin-bottom: 16px;
max-width: 520px;
margin-left: auto;
margin-right: auto;
letter-spacing: 0.02em;
}
.cta-section p {
font-size: 15px;
/* Explicitly light on dark */
color: rgba(251,251,251,0.65);
max-width: 480px;
margin: 0 auto 36px;
line-height: 1.8;
font-weight: 300;
}

/* ── FOOTER ── */
footer {
background: var(–green-dark);
border-top: 1px solid rgba(251,251,251,0.08);
color: rgba(251,251,251,0.38);
text-align: center;
padding: 28px 24px;
font-size: 11px;
letter-spacing: 0.1em;
text-transform: uppercase;
font-weight: 400;
}
footer strong { color: rgba(251,251,251,0.7); font-weight: 400; }

/* ── AGGRESSIVE MOBILE OVERRIDES ── */
@media screen and (max-width: 768px) {
body { font-size: 14px !important; }
.section-title { font-size: 22px !important; }
.hero-name { font-size: 38px !important; }
.hero-location { font-size: 13px !important; }
.hero-meta-item .value { font-size: 15px !important; }
.hero-meta-item .label { font-size: 8px !important; }
.tldr-card .section-title { font-size: 22px !important; }
.tldr-list li { font-size: 13px !important; }
.day-name { font-size: 19px !important; }
.subsection-title { font-size: 17px !important; }
.lodging-name { font-size: 16px !important; }
.lodging-card.featured .lodging-name { font-size: 19px !important; }
.lodging-desc { font-size: 12px !important; }
.section-intro { font-size: 13px !important; line-height: 1.75 !important; }
.event-item { font-size: 13px !important; }
.event-desc strong { font-size: 13px !important; }
.callout { font-size: 13px !important; }
.tldr-card { padding: 24px 20px !important; }
.hero { padding: 48px 20px 44px !important; }
.hero-meta { gap: 20px !important; }
.page-wrap { padding: 0 16px !important; }
.section { padding: 44px 0 36px !important; }
}

/* ── ANIMATIONS ── */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(14px); }
to { opacity: 1; transform: translateY(0); }
}
.hero > * { animation: fadeUp 0.65s ease both; }
.hero .eyebrow { animation-delay: 0.08s; }
.hero-name { animation-delay: 0.22s; }
.hero-location { animation-delay: 0.36s; }
.hero-meta { animation-delay: 0.5s; }

/* ── RESPONSIVE ── */
@media (max-width: 600px) {
.tldr-card { padding: 30px 22px; }
.event-item { grid-template-columns: 1fr; gap: 3px; }
.event-time { padding-top: 0; }
.hero-meta { gap: 28px; }
.page-nav ul { justify-content: flex-start; }
.btn-secondary { margin-left: 0; margin-top: 10px; display: inline-block; }
.hero { padding: 64px 20px 56px; }
.page-wrap { padding: 0 20px; }
}
</style>

</head>
